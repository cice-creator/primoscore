# Copiare i valori nel servizio di hosting. Non salvare password reali nel progetto.
PRIMOSCORE_HOST=0.0.0.0
PRIMOSCORE_PORT=4173
PRIMOSCORE_ADMIN_USER=admin
PRIMOSCORE_ADMIN_PASSWORD=INSERIRE_UNA_PASSWORD_LUNGA_E_UNICA
PRIMOSCORE_HTTPS=1
PRIMOSCORE_DOMAIN=primoscore.it
PRIMOSCORE_RETENTION_DAYS=365

# Brevo: chiave solo lato server
BREVO_API_KEY=INSERIRE_LA_CHIAVE_API_BREVO
BREVO_LIST_ID=INSERIRE_ID_LISTA_LEAD
BREVO_CUSTOM_ATTRIBUTES=0
BREVO_SENDER_EMAIL=notifiche@primoscore.it
BREVO_SENDER_NAME=Primoscore
LEAD_NOTIFICATION_TO=INSERIRE_EMAIL_CHE_RICEVE_I_LEAD

# Notifiche email opzionali
SMTP_HOST=smtp.esempio.it
SMTP_PORT=587
SMTP_TLS=1
SMTP_USER=utente_smtp
SMTP_PASSWORD=password_smtp
SMTP_FROM=Primoscore <notifiche@primoscore.it>
LEAD_NOTIFICATION_TO=indirizzo_destinatario
